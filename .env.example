# Canton Network DevNet (Global Synchronizer)
# Docs: https://docs.canton.network/global-synchronizer/deployment/required-network-parameters
# SV status: https://sync.global/sv-network/
# SDK: Daml 3.4.x (matches DevNet Canton 3.5.x per Splice version matrix)

CANTON_NETWORK=devnet

# JSON Ledger API v2 — used by Go services (core-api, expiry-cron, canton-indexer)
# Validator quickstart suffix: x975 (e.g. App Provider JSON API on 3975)
CANTON_JSON_API_URL=https://participant.devnet.example:3975

# Browser-facing JSON Ledger API v2 (Next.js client components)
NEXT_PUBLIC_CANTON_LEDGER_URL=https://participant.devnet.example:3975
NEXT_PUBLIC_CANTON_ADMIN_PARTY_ID=
NEXT_PUBLIC_CANTON_TEMPLATE_PROPERTY_POOL=RentyVest.PropertyPool:PropertyPool
NEXT_PUBLIC_PLEDGE_META_URI_BASE=https://api.rentyvest.com/metadata/pledges

# gRPC Ledger API — used by Makefile `daml ledger upload-dar` / `daml script`
# Validator quickstart suffix: x901 (e.g. App Provider Ledger API on 3901)
CANTON_LEDGER_HOST=participant.devnet.example
CANTON_LEDGER_PORT=3901
CANTON_LEDGER_TLS=true

# OIDC JWT from your validator Auth0/OIDC setup (required on secured participants)
CANTON_JWT=

# Populated after: make init-devnet (or make deploy-all)
CANTON_ACT_AS_PARTY=
CANTON_READ_AS_PARTY=
CANTON_PROP_MANAGER_PARTY=

# Returned to the browser via POST /auth/exchange for direct Canton submissions
CANTON_LEDGER_TOKEN=

# Faucet / admin mint credentials (falls back to CANTON_JWT / CANTON_ACT_AS_PARTY)
CANTON_ADMIN_TOKEN=
CANTON_ADMIN_PARTY_ID=
CANTON_USDC_ISSUER_CONTRACT_ID=
CANTON_TEMPLATE_USDC_ISSUER=RentyVest.TestUSDC:USDCIssuer
CANTON_TEMPLATE_PROPERTY_POOL=RentyVest.PropertyPool:PropertyPool

# Faucet defaults
FAUCET_USDC_AMOUNT=100000.0
FAUCET_RATE_LIMIT_WINDOW=24h

# Native pledge metadata
PLEDGE_META_URI_BASE=https://api.rentyvest.com/metadata/pledges
PLEDGE_CURRENCY=tUSDC

# Expiry cron worker
EXPIRY_CRON_INTERVAL=5m
EXPIRY_REASON=fundraising deadline elapsed
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
