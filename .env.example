# =============================================================================
# RentyVest environment template
# Copy to repo root:  cp .env.example .env
# Go services, Makefile, and Next.js (apps/web) all read root .env.
# =============================================================================

# --- Next.js (public) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_CORE_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_CANTON_LEDGER_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
NEXT_PUBLIC_CANTON_DAML_PACKAGE_ID=
NEXT_PUBLIC_USDC_CONTRACT_ID=
NEXT_PUBLIC_CANTON_ADMIN_PARTY_ID=
NEXT_PUBLIC_CANTON_TEMPLATE_PROPERTY_POOL=RentyVest.PropertyPool:PropertyPool
NEXT_PUBLIC_CANTON_TEMPLATE_USDC_ASSET=RentyVest.TestUSDC:Asset
NEXT_PUBLIC_PLEDGE_META_URI_BASE=https://api.rentyvest.com/metadata/pledges

# --- Go services (core-api, canton-indexer, expiry-cron) ---
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres?sslmode=require
PRIVY_APP_ID=
PRIVY_APP_SECRET=
SUPABASE_JWT_SECRET=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Canton Network DevNet (5N Sandbox Validator — live ledger) ---
MOCK_LEDGER_MODE=false
CANTON_NETWORK=devnet
CANTON_JSON_API_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
CANTON_LEDGER_HOST=ledger-api.validator.devnet.sandbox.fivenorth.io
CANTON_LEDGER_PORT=443
CANTON_LEDGER_TLS=true

# M2M OAuth (core-api token manager — backend only, never NEXT_PUBLIC_*)
CANTON_OAUTH_URL=https://auth.sandbox.fivenorth.io/application/o/token/
CANTON_CLIENT_ID=
CANTON_CLIENT_SECRET=
CANTON_AUDIENCE=
CANTON_OAUTH_SCOPE=daml_ledger_api
CANTON_M2M_REFRESH_INTERVAL=7h

# Optional static JWT fallback when M2M OAuth is not configured
CANTON_JWT=
CANTON_ACT_AS_PARTY=
CANTON_READ_AS_PARTY=
CANTON_PROP_MANAGER_PARTY=
CANTON_DAML_PACKAGE_ID=
CANTON_USDC_ISSUER_CONTRACT_ID=
CANTON_TEMPLATE_USDC_ASSET=RentyVest.TestUSDC:Asset
CANTON_TEMPLATE_USDC_ISSUER=RentyVest.TestUSDC:USDCIssuer
CANTON_TEMPLATE_PROPERTY_POOL=RentyVest.PropertyPool:PropertyPool

# Ledger user id for JSON API submits (5N M2M JWT sub is typically "6")
CANTON_LEDGER_USER_ID=6
# CANTON_LEDGER_TOKEN=
# CANTON_ADMIN_TOKEN=
# CANTON_ADMIN_PARTY_ID=

# --- Faucet & pledges ---
FAUCET_USDC_AMOUNT=100000.0
FAUCET_RATE_LIMIT_WINDOW=24h
PLEDGE_META_URI_BASE=https://api.rentyvest.com/metadata/pledges
PLEDGE_CURRENCY=tUSDC

# --- Expiry cron ---
EXPIRY_CRON_INTERVAL=5m
EXPIRY_REASON=fundraising deadline elapsed

# --- Observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
